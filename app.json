{
  "expo": {
    "name": "Hymnal",
    "slug": "acchymns",
    "version": "5.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/ios-light.png",
    "scheme": "acchymns",
    "userInterfaceStyle": "automatic",
    "owner": "acc-hymns",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ChristopherW.acchmns",
      "appleTeamId": "AVS62V4S24",
      "associatedDomains": [
        "applinks:acchymns.app",
        "applinks:www.acchymns.app"
      ],
      "entitlements": {
        "com.apple.developer.associated-domains": [
          "applinks:acchymns.app",
          "applinks:www.acchymns.app"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAllowsArbitraryLoads": true,
        "UIDesignRequiresCompatibility": false,
        "UIBackgroundModes": [
          "audio"
        ]
      },
      "icon": {
        "dark": "./assets/icons/ios-dark.png",
        "light": "./assets/icons/ios-light.png",
        "tinted": "./assets/icons/ios-tinted.png"
      },
      "deploymentTarget": "16.4"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "acchymns.app",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.acchymns.app",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.ChristopherW.acchmns"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "meta": {
        "viewport": "width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/splash-icon-dark.png",
          "backgroundColor": "#FFFFFF",
          "imageWidth": 200,
          "resizeMode": "contain",
          "dark": {
            "image": "./assets/icons/splash-icon-light.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/latoregular.ttf",
            "./assets/fonts/latoblack.ttf",
            "./assets/fonts/latobold.ttf"
          ],
          "android": {
            "fonts": [
              {
                "fontFamily": "Lato",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/latoregular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./assets/fonts/latoblack.ttf",
                    "weight": 900
                  },
                  {
                    "path": "./assets/fonts/latobold.ttf",
                    "weight": 700
                  },
                  {
                    "path": "./assets/fonts/latobold.ttf",
                    "weight": 500
                  }
                ]
              }
            ]
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      "expo-audio",
      "expo-localization",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow $(PRODUCT_NAME) to use Face ID."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4"
          },
          "android": {
            "ndkVersion": "29.0.14206865"
          }
        }
      ],
      "expo-web-browser",
      "expo-asset",
      "./plugins/withAndroidSvgFix",
      "./plugins/withGlideFix",
      "./plugins/withMetaspaceFix",
      "expo-image",
      "expo-sharing",
      "expo-status-bar",
      "@rnrepo/expo-config-plugin",
      "@react-native-vector-icons/ionicons",
      "@preeternal/react-native-file-hash"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://acchymns.app"
      },
      "eas": {
        "projectId": "dce778e0-a059-408f-a380-56d56a777daf"
      }
    },
    "runtimeVersion": { "policy": "appVersion" },
    "updates": {
      "url": "https://u.expo.dev/dce778e0-a059-408f-a380-56d56a777daf"
    }
  }
}
