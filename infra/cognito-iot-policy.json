{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "iot:Connect",
        "iot:Publish",
        "iot:Subscribe",
        "iot:Receive"
      ],
      "Resource": [
        "arn:aws:iot:us-east-2:382131451454:client/acchymns-*",
        "arn:aws:iot:us-east-2:382131451454:topic/hymnsign/*/command",
        "arn:aws:iot:us-east-2:382131451454:topicfilter/hymnsign/*/command"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "iot:AttachPolicy",
        "iot:ListAttachedPolicies"
      ],
      "Resource": "arn:aws:iot:us-east-2:382131451454:policy/HymnSignAppPublish"
    }
  ]
}
